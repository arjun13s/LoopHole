{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loophole.dev/schemas/reward_spec.json",
  "title": "RewardSpec",
  "description": "Machine-readable spec of the GRPO scalar reward. PLAN.md §1.4. FROZEN CONTRACT. reward.py must implement this exactly.",
  "type": "object",
  "version": 1,
  "components": {
    "localization_correct": {
      "weight": 1.0,
      "type": "binary",
      "rule": "verdict.predicted_step_id == planted_failure.step_id"
    },
    "failure_type_correct": {
      "weight": 0.3,
      "type": "binary",
      "rule": "verdict.failure_type == planted_failure.failure_type"
    },
    "explanation_score": {
      "weight": 0.5,
      "type": "continuous_0_1",
      "rule": "deterministic fix-by-comparison score in [0,1]",
      "counts_only_if": "localization_correct || failure_type_correct"
    }
  },
  "formula": "reward = 1.0*localization_correct + 0.3*failure_type_correct + (0.5*explanation_score if localization_correct || failure_type_correct else 0.0)",
  "clean_trace": {
    "condition": "planted_failure == null",
    "rule": "reward = 1.0 if verdict.fault_present == false else 0.0"
  },
  "explanation_rubric": {
    "judge": "deterministic fix-by-comparison; no LLM judge in reward path",
    "dimensions": ["process_issue_identified", "corrective_action_coverage", "citation_grounding"],
    "output": "scalar 0..1, thresholded; used when localization_correct or failure_type_correct is true"
  },
  "stretch_hook_design_y": {
    "note": "DO NOT IMPLEMENT YET. When the gate head exists, add: reward -= lambda * tokens_used."
  }
}

# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored (see root .gitignore) — NEVER commit real keys/tokens.
#
# NOTE on the HUD MCP server (.mcp.json):
#   Claude Code expands ${HUD_API_KEY} from the SHELL ENVIRONMENT it launches in,
#   not from this .env file automatically. So to activate the loop-auditor MCP:
#       export HUD_API_KEY=...        # in the shell BEFORE starting claude
#   (Putting it in .env as well is fine for other tooling that loads .env.)

# HUD — RL env + loop-auditor MCP server (Person 2's HUD workspace).
HUD_API_KEY=

# Anthropic — explanation-rubric judge (separate strong model; never the trained agent).
ANTHROPIC_API_KEY=

# Modal — Person 3 b1 compute (set only when wiring Modal b1).
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
